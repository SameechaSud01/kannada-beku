{
  "expo": {
    "name": "kannada-beku",
    "slug": "kannada-baa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFDF5"
    },
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Kannada Beku records your voice so you can hear yourself practice phrases. Recordings stay on your device.",
        "NSUserNotificationsUsageDescription": "Kannada Beku sends one daily reminder at the time you choose so you keep your streak.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.samsud01.kannadabeku",
      "buildNumber": "5"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.samsud01.kannadabeku",
      "versionCode": 4
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "kannada-beku",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-notifications",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.734110592411-t6ebm9jukos396u6beei30ccgasu2ejq"
        }
      ],
      "expo-apple-authentication",
      [
        "expo-build-properties",
        {
          "ios": {
            "extraPods": [
              { "name": "GoogleUtilities", "modular_headers": true },
              { "name": "RecaptchaInterop", "modular_headers": true }
            ]
          }
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "adccfc42-2b05-4f37-bffb-d785e3ed8dc3"
      }
    }
  }
}
