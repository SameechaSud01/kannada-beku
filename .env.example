# Supabase — copy this file to `.env` and fill in your own values.
# Both are exposed to the client at runtime via `process.env.EXPO_PUBLIC_*`.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-publishable-anon-key

# Sentry crash reporting (public client DSN, not a secret — safe to embed).
# Leave empty to disable reporting entirely; also disabled in dev builds.
# Add the real DSN to the eas.json production/preview env to ship reporting.
EXPO_PUBLIC_SENTRY_DSN=

# Google Sign-In OAuth client IDs (public identifiers, not secrets).
# Web client ID = the audience Supabase validates against; required on Android.
# iOS client ID = used by the native iOS SDK (its reversed form is also the
# `iosUrlScheme` in app.json's google-signin plugin).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=yyyy.apps.googleusercontent.com

# Azure Speech (Neural TTS) — used ONLY by `npm run gen:audio` to pre-generate
# bundled Kannada audio. Generation-time only: NOT exposed to the client, NEVER
# prefixed EXPO_PUBLIC_, never shipped in the app.
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=centralindia

# Supabase service_role key — SECRET. Used ONLY by `npm run gen:audio` to read
# RLS-gated content tables (the anon key returns 0 rows). Generation-time only:
# NOT exposed to the client, NEVER prefixed EXPO_PUBLIC_, never shipped/committed.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
