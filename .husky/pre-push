#!/bin/sh
# Block pushes to protected branches, then run TypeScript + security checks.
set -eu

# git feeds "<local_ref> <local_sha> <remote_ref> <remote_sha>" on stdin.
while read -r local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/heads/main|refs/heads/master)
      branch="${remote_ref#refs/heads/}"
      echo ""
      echo "========================================="
      echo "  Push to protected branch '$branch' is blocked."
      echo "========================================="
      echo ""
      echo "All changes must land on '$branch' via a pull request from a feature branch."
      echo ""
      echo "  git switch -c feature/<short-name>"
      echo "  git push -u origin feature/<short-name>"
      echo ""
      echo "To bypass in a true emergency: git push --no-verify"
      exit 1
      ;;
  esac
done

echo ""
echo "========================================="
echo "  Pre-Push Pipeline - Kannada Beku"
echo "========================================="
echo ""

echo "[ Step 1/4 ] Running TypeScript type check..."
if tsc --noEmit; then
  echo "  TypeScript: PASS"
else
  echo "  TypeScript: FAIL"
  echo ""
  echo "  Fix TypeScript errors before pushing."
  exit 1
fi

echo ""
echo "[ Step 2/4 ] Running ESLint..."
if node node_modules/eslint/bin/eslint.js .; then
  echo "  ESLint: PASS"
else
  echo "  ESLint: FAIL"
  echo ""
  echo "  Fix lint errors before pushing (run: npm run lint:fix)."
  exit 1
fi

echo ""
echo "[ Step 3/4 ] Running security scan..."
SCRIPT_DIR="$(git rev-parse --show-toplevel)/scripts"
if [ -f "$SCRIPT_DIR/security-scan.sh" ]; then
  if bash "$SCRIPT_DIR/security-scan.sh"; then
    echo ""
  else
    echo ""
    echo "  Security scan failed. Push blocked."
    exit 1
  fi
else
  echo "  Security scan script missing — failing closed (audit H2). Push blocked."
  exit 1
fi

echo ""
echo "[ Step 4/4 ] Running tests..."
if jest --silent; then
  echo "  Tests: PASS"
else
  echo "  Tests: FAIL"
  echo ""
  echo "  Fix failing tests before pushing."
  exit 1
fi

echo ""
echo "========================================="
echo "  All checks passed. Pushing..."
echo "========================================="
echo ""
